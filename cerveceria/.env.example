# =============================================
# Plantilla de variables de entorno
# COPIAR A .env Y RELLENAR CON VALORES REALES
# =============================================

# ─── BASE DE DATOS ─────────────────────────
# URL de conexión PostgreSQL
DATABASE_URL=jdbc:postgresql://localhost:5432/cocobongo_db

# Usuario de PostgreSQL
DATABASE_USERNAME=postgres

# Contraseña de PostgreSQL
DATABASE_PASSWORD=tu_password_aqui

# ─── JWT SECRET ────────────────────────────
# Clave secreta para JWT (mínimo 256 bits)
# Generar: openssl rand -base64 32
JWT_SECRET=tu_jwt_secret_super_seguro_cambiar_para_produccion

# ─── ADMIN CREDENTIALS ─────────────────────
# Contraseña del usuario admin inicial
ADMIN_PASSWORD=admin123

# ─── PUERTO SERVIDOR ───────────────────────
PORT=8082
